# Trade.gov Developer Portal (subscription key): https://developer.trade.gov/
TRADE_GOV_API_KEY=
# Optional override; default hits data.trade.gov CSL v1 search
# TRADE_GOV_CSL_SEARCH_URL=https://data.trade.gov/consolidated_screening_list/v1/search
# Post-filter for fuzzy CSL hits: 0–1, higher = stricter (fewer weak matches). Default 0.78.
# SANCTIONS_NAME_SIMILARITY_THRESHOLD=0.78

# Google AI Studio — Gemini (defaults: cheapest Flash tier, gemini-2.5-flash-lite)
GOOGLE_API_KEY=
# Paid tier: enable billing in AI Studio / Google Cloud for higher limits than free tier.
# Stronger (costlier) Flash: GEMINI_*_MODEL=gemini-2.5-flash
# GEMINI_SANCTIONS_MODEL=gemini-2.5-flash-lite
# GEMINI_REGULATORY_MODEL=gemini-2.5-flash-lite
# Supply Chain Sentinel what-if (markdown + JSON)
# GEMINI_SIMULATION_MODEL=gemini-2.5-flash
# Chroma dir for profiles (relative to backend/)
# SENTINEL_CHROMA_PATH=sentinel_chroma

# Regulatory RAG (paths relative to backend/ unless absolute)
# REGULATORY_CHROMA_PATH=chroma_db
# REGULATORY_PDFS_PATH=data/regulatory_pdfs
# REGULATORY_COLLECTION_NAME=clearpath_regulatory
# REGULATORY_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: sentence-transformers cache
# HF_HOME=./.cache/huggingface

# CORS: comma-separated origins allowed to call the API (Next.js dev is usually http://localhost:3000)
CORS_ORIGINS=http://localhost:3000
