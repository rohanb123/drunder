# ── Browser Use Cloud ────────────────────────────────────────────────────────
# Create a key at: https://cloud.browser-use.com/settings?tab=api-keys&new=1
BROWSER_USE_API_KEY=bu_your_key_here

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Used to generate the HubSpot action plan from researched company data.
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_your_key_here

# ── HubSpot (optional) ───────────────────────────────────────────────────────
# If you want the agent to skip the HubSpot login step, create a Browser Use
# profile, log in once manually, and paste the profile ID here.
# See: https://docs.browser-use.com/cloud/guides/authentication
# BROWSER_USE_HUBSPOT_PROFILE_ID=prof_xxxxxxxxxxxx
