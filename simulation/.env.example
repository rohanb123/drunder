# Next.js (project root `.env.local` or `.env`)
# Use `npm run dev` — it runs Convex sync then Next.js. Convex writes `.env.local` with
# CONVEX_DEPLOYMENT and NEXT_PUBLIC_CONVEX_URL on first link. If you only run `next dev`,
# functions are never pushed and you get "Could not find public function".
NEXT_PUBLIC_CONVEX_URL=

# Clearpath FastAPI (sanctions + regulatory report). No trailing slash.
# Example: http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=

# Live streaming what-if (Next.js route /api/simulate/stream). Same key as Convex is fine.
GEMINI_API_KEY=

# Convex backend only (not read by Next.js at runtime for the simulator action):
#   npx convex env set GEMINI_API_KEY your_key_here
#
# Prefer a key from https://aistudio.google.com/apikey (works with this app out of the box).
# If you use a Google Cloud "API key" instead and see 403 API_KEY_SERVICE_BLOCKED:
#   - APIs & Services → Enable "Generative Language API" on that GCP project
#   - APIs & Services → Credentials → edit the key → API restrictions must include
#     "Generative Language API" (or "Don't restrict key" for testing)
#   - Application restrictions: "None" or a type that allows Convex servers (not HTTP referrer-only)
# Re-set the key after fixing: npx convex env set GEMINI_API_KEY "..."
